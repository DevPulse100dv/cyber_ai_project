# Environment Configuration for Agentic Cyber Security System
# Copy this file to .env and fill in your values

# LLM Provider API Keys (for BYOK mode)
# OpenAI is recommended when using GitHub Copilot SDK due to better token limits
OPENAI_API_KEY=sk-your-openai-key-here

# Alternative providers (may have token limits with Copilot SDK)
# GROQ_API_KEY=gsk-your-groq-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Azure OpenAI Configuration (if using Azure)
# AZURE_OPENAI_API_KEY=your_azure_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Ollama Configuration (Local)
# NO API KEY REQUIRED usually, but you can set base URL if remote
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Notification Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# SIEM Integration (optional)
# SPLUNK_HOST=localhost
# SPLUNK_PORT=8089
# SPLUNK_USERNAME=admin
# SPLUNK_PASSWORD=your_password

# Elasticsearch Integration (optional)
# ELASTICSEARCH_HOST=localhost
# ELASTICSEARCH_PORT=9200

# Configuration file path (optional, defaults to config/default.yaml)
# CONFIG_FILE=config/local.yaml

# Log level
LOG_LEVEL=INFO
